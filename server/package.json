{
  "name": "moydrug-server",
  "version": "1.0.0",
  "description": "Мой Друг — AI backend proxy (Fastify 5)",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "pm2:start": "pm2 start index.js --name moydrug-server --max-memory-restart 512M",
    "pm2:restart": "pm2 restart moydrug-server",
    "pm2:logs": "pm2 logs moydrug-server"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "pino-pretty": "^13.0.0"
  }
}
